  data_group1 = grp1_os,
  data_group2 = grp2_os,
  time_var    = "TIME",
  event_var   = "EVENT",
  tau         = 36
)
print(res)

# -------------------------------------------------------------------
# 2. Overall + single subgroup: REGION, OS
# -------------------------------------------------------------------
res_region <- summarytable(
  data_group1   = grp1_os,
  data_group2   = grp2_os,
  time_var      = "TIME",
  event_var     = "EVENT",
  tau           = 36,
  subgroup_vars = "REGION"
)
print(res_region)

# -------------------------------------------------------------------
# 3. Overall + multiple subgroup variables, OS
# -------------------------------------------------------------------
res_os <- summarytable(
  data_group1   = grp1_os,
