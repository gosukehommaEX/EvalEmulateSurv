  time_var      = "TIME",
  event_var     = "EVENT",
  tau           = 36,
  subgroup_vars = c("SEX", "REGION")
)
print(res_os)

# -------------------------------------------------------------------
# 4. Two-way interaction: SEX x REGION, OS
# -------------------------------------------------------------------
res_inter <- summarytable(
  data_group1   = grp1_os,
